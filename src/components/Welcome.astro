---
const { productos } = Astro.props
---

<section class="w-full max-w-6xl m-auto px-4 py-8">
  <div class="w-full h-80">
    <img src="/banner.webp" alt="banner" class="hidden md:flex" />
    <img
      src="/banner-mobil.webp"
      alt="banner"
      class="w-full h-52 md:hidden"
    />
  </div>
  <section class="py-4">
    <ul class="gridContainer">
      {
        productos?.map((p) => (
          
          <li>
            <div class="group relative  rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition duration-300">

  
  <img 
    src={p.imagen_url} 
    alt="Uñas acrílicas" 
    class="w-full h-100 object-cover group-hover:scale-110 transition duration-500"
  />

  
  <div class="absolute inset-0 bg-linear-to-t from-black/70 via-black/0 to-transparent"></div>

  
  <div class="absolute bottom-0 p-4 w-full text-white">
    
    <h3 class="text-lg font-semibold tracking-wide">
      {p.titulo}
    </h3>

    <p class="text-sm opacity-80">
      Diseño premium y duradero
    </p>

    <div class="flex items-center justify-between mt-3">
      <h4 class="text-lg font-bold">
        <span class="font-bold">$</span> {Number(p.precio).toLocaleString('es-AR')}
      </h4>

      <button class="bg-[#E6D8F2]  text-black text-xs px-3 py-1 rounded-full font-medium hover:bg-purple-300 transition cursor-pointer">
        Agregar al carrito
      </button>
    </div>

  </div>
</div>
          </li>
        ))
      }
    </ul>
  </section>
</section>

<style>
  .gridContainer {
    display: grid;
    width: 100%;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
    overflow-x: auto;
  }
</style>
