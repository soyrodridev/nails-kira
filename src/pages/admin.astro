---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";

const { data: productos } = await supabase
  .from("productos")
  .select("*")
  .order("created_at", { ascending: false });
import "../styles/global.css";
---

<Layout>
  
  <div class="fixed w-full h-dvh bg-[#F9F7FB]/50 z-[-1]"></div>
  <section class="w-full max-w-6xl px-4 m-auto">
    <h1 class="text-3xl">Panel Admin📃</h1>

    <form id="form" class="flex flex-col gap-4 py-4 max-w-2xl m-auto">
      <input
        type="text"
        id="titulo"
        placeholder="Titulo"
        required
        class="w-full h-11 border border-fuchsia-900/50 pl-4 rounded-2xl text-[1.1rem]"
      />
      <input
        type="number"
        id="precio"
        placeholder="Precio"
        required
        class="w-full h-11 border border-fuchsia-900/50 pl-4 rounded-2xl text-[1.1rem]"
      />
      <div>
        <label class="custum-file-upload" for="imagen">
          <div id="contenedor-preview" class="flex justify-center items-center">
            <div class="icon" id="icon-upload">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill=""
                viewBox="0 0 24 24"
                data-astro-cid-2zp6q64z=""
                ><g
                  stroke-width="0"
                  id="SVGRepo_bgCarrier"
                  data-astro-cid-2zp6q64z=""></g><g
                  stroke-linejoin="round"
                  stroke-linecap="round"
                  id="SVGRepo_tracerCarrier"
                  data-astro-cid-2zp6q64z=""></g><g
                  id="SVGRepo_iconCarrier"
                  data-astro-cid-2zp6q64z=""
                >
                  <path
                    fill=""
                    d="M10 1C9.73478 1 9.48043 1.10536 9.29289 1.29289L3.29289 7.29289C3.10536 7.48043 3 7.73478 3 8V20C3 21.6569 4.34315 23 6 23H7C7.55228 23 8 22.5523 8 22C8 21.4477 7.55228 21 7 21H6C5.44772 21 5 20.5523 5 20V9H10C10.5523 9 11 8.55228 11 8V3H18C18.5523 3 19 3.44772 19 4V9C19 9.55228 19.4477 10 20 10C20.5523 10 21 9.55228 21 9V4C21 2.34315 19.6569 1 18 1H10ZM9 7H6.41421L9 4.41421V7ZM14 15.5C14 14.1193 15.1193 13 16.5 13C17.8807 13 19 14.1193 19 15.5V16V17H20C21.1046 17 22 17.8954 22 19C22 20.1046 21.1046 21 20 21H13C11.8954 21 11 20.1046 11 19C11 17.8954 11.8954 17 13 17H14V16V15.5ZM16.5 11C14.142 11 12.2076 12.8136 12.0156 15.122C10.2825 15.5606 9 17.1305 9 19C9 21.2091 10.7909 23 13 23H20C22.2091 23 24 21.2091 24 19C24 17.1305 22.7175 15.5606 20.9844 15.122C20.7924 12.8136 18.858 11 16.5 11Z"
                    clip-rule="evenodd"
                    fill-rule="evenodd"
                    data-astro-cid-2zp6q64z=""></path>
                </g></svg
              >
            </div>

            <img
              id="preview"
              src=""
              class="hidden w-40 h-40 object-cover rounded-2xl"
            />
          </div>

          <div class="text">
            <span id="texto-imagen">Subir imagen</span>
          </div>
          <input type="file" required id="imagen" />
        </label>
      </div>

      <button
        type="submit"
        class="w-full h-11 bg-purple-500 rounded-3xl text-white">Guardar</button
      >
    </form>

    <h2 class="text-2xl mt-10">Productos</h2>

    <div class="grid grid-cols-1 gap-4">
      {
        productos?.map((p, index) => (
          <div class="bg-white space-y-3 p-4 rounded-lg shadow grid grid-cols-1 md:grid-cols-2">
            <div class="flex items-center space-x-2">
              <picture>
                <img src={p.imagen_url} alt={p.titulo} class="w-20" />
              </picture>

              <div>
                <div class="flex items-center space-x-2 text-sm">
                  <div>
                    <a href="#" class="text-blue-500 font-bold hover:underline">
                      #{String(index + 1).padStart(4, "0")}
                    </a>
                  </div>

                  <div class="text-gray-500">
                    {new Date(p.created_at).toLocaleDateString("es-AR")}
                  </div>

                  <div>
                    <span class="p-1.5 text-xs font-medium uppercase tracking-wider text-green-800 bg-green-200 rounded-lg bg-opacity-50">
                      Disponible
                    </span>
                  </div>
                </div>

                <div class="text-sm text-gray-700">{p.titulo}</div>

                <div class="text-sm font-medium text-black">
                  $ {Number(p.precio).toLocaleString("es-AR")}
                </div>
              </div>
            </div>

            <div class="flex w-full md:justify-end md:items-center space-x-4">
              <button
                class="p-1.5 text-[1rem] font-medium uppercase flex justify-center items-center cursor-pointer tracking-wider text-green-800 bg-green-200 rounded-lg bg-opacity-50"
                data-id={p.id}
                data-titulo={p.titulo}
                data-precio={p.precio}
                onclick="editarDesdeBoton(this)"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="icon icon-tabler icons-tabler-outline icon-tabler-edit"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                  <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" />
                  <path d="M16 5l3 3" />
                </svg>
                Editar
              </button>

              <button
                class="p-1.5 text-[1rem] flex justify-center items-center cursor-pointer space-x-4 font-medium uppercase tracking-wider text-red-800 bg-red-200 rounded-lg bg-opacity-50"
                onclick={`eliminar('${p.id}')`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="icon icon-tabler icons-tabler-outline icon-tabler-file-x"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M14 3v4a1 1 0 0 0 1 1h4" />
                  <path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2" />
                  <path d="M10 12l4 4m0 -4l-4 4" />
                </svg>
                Eliminar
              </button>
            </div>
          </div>
        ))
      }
    </div>
  </section>
  <div id="toast"
  class="flex space-x-2 h-14 items-center px-4 fixed bg-blue-100 rounded-full bottom-4 right-4 shadow-lg
  opacity-0 translate-y-10 transition-all duration-300">

  <span>Publicación realizada</span>

  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"
    class="icon icon-tabler icons-tabler-filled icon-tabler-circle-check text-green-400 text-xl">

    <path stroke="none" d="M0 0h24v24H0z" fill="none" />

    <path d="M17 3.34a10 10 0 1 1 -14.995 8.984l-.005 -.324l.005 -.324a10 10 0 0 1 14.995 -8.336zm-1.293 5.953a1 1 0 0 0 -1.32 -.083l-.094 .083l-3.293 3.292l-1.293 -1.292l-.094 -.083a1 1 0 0 0 -1.403 1.403l.083 .094l2 2l.094 .083a1 1 0 0 0 1.226 0l.094 -.083l4 -4l.083 -.094a1 1 0 0 0 -.083 -1.32z" />

  </svg>
</div>
</Layout>

<style>
  .custum-file-upload {
    height: 200px;
    width: 300px;
    display: flex;
    flex-direction: column;
    align-items: space-between;
    gap: 20px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    border: 2px dashed #cacaca;
    background-color: rgba(255, 255, 255, 1);
    padding: 1.5rem;
    border-radius: 10px;
    box-shadow: 0px 48px 35px -48px rgba(0, 0, 0, 0.1);
  }

  .custum-file-upload .icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custum-file-upload .icon svg {
    height: 80px;
    fill: rgba(75, 85, 99, 1);
  }

  .custum-file-upload .text {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custum-file-upload .text span {
    font-weight: 400;
    color: rgba(75, 85, 99, 1);
  }

  .custum-file-upload input {
    display: none;
  }
</style>

<script>
  import { supabase } from "../lib/supabase";

  const form = document.getElementById("form");
  let editandoId = null;

  const inputImagen = document.getElementById("imagen");
  const preview = document.getElementById("preview");
  const textoImagen = document.getElementById("texto-imagen");
  const iconUpload = document.getElementById("icon-upload");

  function mostrarToast() {
  const toast = document.getElementById('toast')

  // mostrar
  toast.classList.remove('opacity-0', 'translate-y-10')

  // ocultar
  setTimeout(() => {
    toast.classList.add('opacity-0', 'translate-y-10')
  }, 3000)
}

  inputImagen.addEventListener("change", () => {
    const file = inputImagen.files[0];

    if (!file) return;

    const imageURL = URL.createObjectURL(file);

    preview.src = imageURL;

    preview.classList.remove("hidden");

    // ocultar svg COMPLETAMENTE
    iconUpload.style.display = "none";

    textoImagen.textContent = file.name;
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const titulo = document.getElementById("titulo").value;
    const precio = document.getElementById("precio").value;
    const file = document.getElementById("imagen").files[0];

    let imageUrl = null;

    // SOLO subir imagen si hay archivo
    if (file) {
      const fileName = Date.now() + "-" + file.name;

      const { error: uploadError } = await supabase.storage
        .from("productos")
        .upload(fileName, file);

      if (uploadError) {
        alert("Error subiendo imagen");
        return;
      }

      const { data } = supabase.storage
        .from("productos")
        .getPublicUrl(fileName);

      imageUrl = data.publicUrl;
    }

    if (editandoId) {
      // UPDATE
      const updateData = {
        titulo,
        precio,
      };

      if (imageUrl) {
        updateData.imagen_url = imageUrl;
      }

      const { error } = await supabase
        .from("productos")
        .update(updateData)
        .eq("id", editandoId);

      if (!error) {
        alert("Producto actualizado ✅");
        editandoId = null;
        location.reload();
      }
    } else {
      // INSERT
      const { error } = await supabase.from("productos").insert([
        {
          titulo,
          precio,
          imagen_url: imageUrl,
        },
      ]);

      if (!error) {
        mostrarToast()
        location.reload();
      }
    }
  });

  // 🔴 FUERA del submit
  async function eliminar(id) {
    const confirmar = confirm("¿Eliminar producto?");

    if (!confirmar) return;

    // buscar producto
    const { data: producto, error: fetchError } = await supabase
      .from("productos")
      .select("imagen_url")
      .eq("id", id)
      .single();

    if (fetchError) {
      alert("Error buscando producto");
      return;
    }

    const imageUrl = producto.imagen_url;

    // ruta REAL del storage
    const filePath = imageUrl.split("/storage/v1/object/public/productos/")[1];

    // eliminar imagen
    const { error: storageError } = await supabase.storage
      .from("productos")
      .remove([filePath]);

    if (storageError) {
      console.log(storageError);
      alert("Error eliminando imagen");
      return;
    }

    // eliminar producto
    const { error } = await supabase.from("productos").delete().eq("id", id);

    if (error) {
      alert("Error eliminando producto");
    } else {
      alert("Producto eliminado ✅");
      location.reload();
    }
  }
  // 🔴 FUERA del submit
  function editar(id, titulo, precio) {
    document.getElementById("titulo").value = titulo;
    document.getElementById("precio").value = precio;

    editandoId = id;
  }

  // ✅ NUEVA función segura
  function editarDesdeBoton(btn) {
    const id = btn.dataset.id;
    const titulo = btn.dataset.titulo;
    const precio = btn.dataset.precio;

    editar(id, titulo, precio);
  }

  // 👇 HACERLAS GLOBALES
  globalThis.eliminar = eliminar;
  globalThis.editar = editar;
  globalThis.editarDesdeBoton = editarDesdeBoton;
</script>
