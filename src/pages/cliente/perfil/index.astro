---
import PerfilForm from "../../../components/cliente/PerfilForm";
import ClientLayout from "../../../layouts/ClientLayout.astro";
import { supabaseClient as supabase } from "../../../lib/supabase";

const userAuth = Astro.locals.user;

if (!userAuth) {
  return Astro.redirect("/login");
}

// Obtenemos los datos desde la tabla 'perfiles'
const { data: perfil, error } = await supabase
  .from("perfiles")
  .select("*")
  .eq("id", userAuth.id)
  .single();

const userData = {
  ...userAuth,
  nombre: perfil?.username || "",
  telefono: perfil?.telefono || "",
  email: userAuth.email
};
---

<ClientLayout username={userData.nombre}>
  <PerfilForm user={userData} client:load />
</ClientLayout>